# Copy to .env next to the compose file and fill in. Full reference:
# docs/plan/11-deployment.md §3. Keep .env at 0600 permissions.

# --- roles (set per compose file; here for reference) ---
# EL_WORKERS_INCLUDE=api,ingest        # main VM
# EL_WORKERS_INCLUDE=media             # GPU VM
# EL_QUEUES_EXCLUDE=facialRecognition  # 2nd..Nth GPU VM only

# --- database ---
DB_HOSTNAME=database                   # GPU VM: tailnet IP of the main VM
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_DATABASE_NAME=eventlens

# --- redis ---
REDIS_HOSTNAME=redis                   # GPU VM: tailnet IP of the main VM
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# --- Cloudflare R2 (bucket-scoped token; separate tokens per VM) ---
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=eventlens-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- ML sidecar (GPU VM) ---
MACHINE_LEARNING_URL=http://ml:3003

# --- cloud import OAuth (M5) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- email (M4; bootstrap values, runtime-editable in system_config) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- app ---
EL_PUBLIC_BASE_URL=https://events.example.com
# 32-byte hex; encrypts Drive/OneDrive refresh tokens. Back up like a DB
# credential — loss forces every org to reconnect (risk R11).
EL_TOKEN_ENCRYPTION_KEY=
EL_SESSION_TTL_DAYS=90
