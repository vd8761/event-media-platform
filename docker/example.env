# Copy to .env next to the compose file and fill in. Full reference:
# docs/plan/11-deployment.md §3. Keep .env at 0600 permissions.

# --- roles (set per compose file; here for reference) ---
# EL_WORKERS_INCLUDE=api,ingest        # main VM
# EL_WORKERS_INCLUDE=media             # GPU VM
# EL_QUEUES_EXCLUDE=facialRecognition  # 2nd..Nth GPU VM only

# --- database ---
# One connection string for every environment. TLS is required automatically
# for any non-local host; append ?sslmode=no-verify for a self-signed cert, or
# ?sslmode=disable to force it off.
#   self-hosted compose : postgres://postgres:change-me@database:5432/eventlens
#   Neon                : postgres://user:pw@ep-xxx.region.aws.neon.tech/eventlens?sslmode=require
DATABASE_URL=postgres://postgres:change-me@database:5432/eventlens
# Only used by the Postgres container in docker-compose.main.yml — keep these
# in step with the credentials inside DATABASE_URL above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=eventlens
# Neon (and most managed Postgres) cannot install VectorChord — use pgvector's
# HNSW index there. Left unset this assumes VectorChord, and migration 0001
# will fail on a provider that does not have it.
# DB_VECTOR_EXTENSION=pgvector
# Set on the GPU worker so two processes do not race the same migration.
# DB_SKIP_MIGRATIONS=true

# --- redis ---
# rediss:// enables TLS, which Upstash requires. The db index rides in the path.
#   self-hosted compose : redis://:change-me@redis:6379
#   Upstash             : rediss://default:<token>@<endpoint>.upstash.io:6379
REDIS_URL=redis://:change-me@redis:6379
# Only used by the Valkey container in docker-compose.main.yml — keep in step
# with the password inside REDIS_URL above.
REDIS_PASSWORD=change-me
# Discrete alternative to REDIS_URL (still used by the local dev compose):
# REDIS_HOSTNAME=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=change-me
# REDIS_TLS=true

# --- Cloudflare R2 (bucket-scoped token; separate tokens per VM) ---
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=eventlens-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- ML sidecar (GPU VM) ---
MACHINE_LEARNING_URL=http://ml:3003

# --- cloud import OAuth (M5) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- email (M4; bootstrap values, runtime-editable in system_config) ---
# Two providers. With EMAIL_PROVIDER unset, Resend is used when RESEND_API_KEY
# is present, otherwise SMTP.
EMAIL_FROM=EventLens <noreply@example.com>

# Option A — Resend's HTTP API:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx

# Option B — SMTP (Mailpit locally, Resend's SMTP gateway, SES, anything else).
# For Resend over SMTP: host smtp.resend.com, port 465, username `resend`,
# password = the API key.
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Defaults to true only on port 465; set explicitly to override.
# SMTP_SECURE=true

# --- app ---
EL_PUBLIC_BASE_URL=https://events.example.com
# 32-byte hex; encrypts Drive/OneDrive refresh tokens. Back up like a DB
# credential — loss forces every org to reconnect (risk R11).
EL_TOKEN_ENCRYPTION_KEY=
EL_SESSION_TTL_DAYS=90

# --- JarvisLabs GPU control (API host only) ---
# Lets Admin → GPU worker pause/resume the GPU box. JarvisLabs has no REST API,
# so the backend runs the `jl` CLI (shipped in the image) as a child process.
# The CLI reads this variable directly — no `jl setup` needed.
JL_API_KEY=
# Override only if the binary is not on PATH as `jl`.
# JL_BINARY=/opt/jarvislabs/bin/jl
