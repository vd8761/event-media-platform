# Local development against docker/docker-compose.dev.yml — copy to
# apps/backend/.env. This is a completely offline setup: MinIO stands in for
# Cloudflare R2 and Mailpit for Resend, over the same code paths, so no
# managed service (R2, Resend, Upstash, Neon) is involved.
#
#   cd docker && docker compose -f docker-compose.dev.yml up -d
#   pnpm --filter backend start:dev

EL_ENV=development
EL_PORT=3001
EL_PUBLIC_BASE_URL=http://localhost:5173

# --- database (compose publishes Postgres on host port 5433) ---
# This is also the built-in default, so it can be omitted entirely.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/eventlens

# --- redis (compose publishes Valkey on 6379) ---
# Also the default. Use rediss:// here to point at Upstash instead.
REDIS_URL=redis://localhost:6379

# --- storage: MinIO standing in for R2 ---
# Same @aws-sdk/client-s3 path as production; only the endpoint differs.
R2_ENDPOINT=http://localhost:9000
R2_BUCKET=eventlens-media
R2_ACCESS_KEY_ID=eventlens
R2_SECRET_ACCESS_KEY=eventlens-secret

# --- email: Mailpit standing in for Resend ---
# No auth, no TLS; read the delivered mail at http://localhost:8025.
EMAIL_PROVIDER=smtp
EMAIL_FROM=EventLens <noreply@eventlens.local>
SMTP_HOST=localhost
SMTP_PORT=1025

# --- ML sidecar (CPU build from the dev compose) ---
MACHINE_LEARNING_URL=http://localhost:3003
EL_ML_DEVICE=cpu

# --- staging + cache scratch dirs (absolute paths; created on boot) ---
# The container defaults (/staging, /cache) are not writable on a dev host.
EL_STAGING_FOLDER=./.staging
EL_CACHE_FOLDER=./.cache

# 32-byte hex; only needed to connect Google Drive / OneDrive locally.
# EL_TOKEN_ENCRYPTION_KEY=
